// Fetch JSON from GitHub repository
async function fetchGroceries() {
    const response = await fetch('https://raw.githubusercontent.com/lesterdabeast/fininifrontendpage/refs/heads/main/barcode.json');
    const data = await response.json();
    return data;
}

// Function to randomly select an item from each category
function getRandomItem(category, groceryData) {
    const items = groceryData[category];
    const randomIndex = Math.floor(Math.random() * items.length);
    return items[randomIndex];
}

// Function to generate the receipt and barcode
async function generateReceipt() {
    const groceryData = await fetchGroceries();  // Fetch data from GitHub

    // Randomly select 1 item from each category
    const selectedItems = [
        getRandomItem('milk', groceryData),
        getRandomItem('bread', groceryData),
        getRandomItem('meat', groceryData),
        getRandomItem('cereal', groceryData)
    ];

    // Generate a barcode data string (combine all UPCs)
    const barcodeData = selectedItems.map(item => item.price.toString()).join('');

    // Display a message for barcode scanning
    document.getElementById('barcodeHeader').style.display = 'block';
    document.getElementById('receiptDetails').innerHTML = '<h2>Your Food Package Barcode:</h2>';

    // Generate Barcode (using JsBarcode for UPC encoding)
    JsBarcode("#barcode", barcodeData, {
        format: "UPC",
        lineColor: "#ffffff",  // White barcode lines
        width: 3,
        height: 100,
        displayValue: false  // Don't display the numeric value under the barcode
    });

    // Display the Barcode
    document.getElementById('barcode').style.display = 'block';

    // Generate PDF Receipt using jsPDF
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();

    // Title of the receipt
    doc.setFontSize(22);
    doc.text("Finini Grocery Receipt", 20, 30);

    // Add UPC Codes and Items to the PDF
    doc.setFontSize(14);
    doc.text("Your Selected Food Package:", 20, 50);

    let total = 0;
    selectedItems.forEach((item, index) => {
        doc.text(`${item.brand} - $${item.price.toFixed(2)}`, 20, 60 + (index * 10));
        total += item.price;
    });

    // Add Total Cost to PDF
    doc.text(`Total: $${total.toFixed(2)}`, 20, 60 + (selectedItems.length * 10));

    // Add Barcode to PDF
    doc.addImage(document.getElementById('barcode'), 'PNG', 20, 120, 170, 40);

    // Save the generated PDF as "receipt.pdf"
    doc.save('receipt.pdf');
}
